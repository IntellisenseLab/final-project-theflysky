<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="qbot" canonical_link="base_link">

    <pose>0 0 0 0 0 0</pose>

    <!-- Base -->
    <link name="base_link">
      <pose>0 0 0.05949 0 0 0</pose>
      <inertial>
        <mass>2.4</mass>
        <inertia>
          <ixx>0.019995</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.019995</iyy>
          <iyz>0</iyz>
          <izz>0.03675</izz>
        </inertia>
      </inertial>
      <visual name="base_visual">
        <geometry>
          <cylinder>
            <length>0.10938</length>
            <radius>0.178</radius>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <collision name="base_collision">
        <geometry>
          <cylinder>
            <length>0.10938</length>
            <radius>0.178</radius>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- Left wheel -->
    <link name="wheel_left_link">
      <pose relative_to="base_link">0 0.193 -0.0245 -1.57079632679 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>0.001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.001</iyy>
          <iyz>0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <visual name="wheel_left_visual">
        <geometry>
          <cylinder>
            <length>0.03</length>
            <radius>0.05</radius>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <collision name="wheel_left_collision">
        <geometry>
          <cylinder>
            <length>0.03</length>
            <radius>0.05</radius>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- Right wheel -->
    <link name="wheel_right_link">
      <pose relative_to="base_link">0 -0.193 -0.0245 -1.57079632679 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>0.001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.001</iyy>
          <iyz>0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <visual name="wheel_right_visual">
        <geometry>
          <cylinder>
            <length>0.03</length>
            <radius>0.05</radius>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <collision name="wheel_right_collision">
        <geometry>
          <cylinder>
            <length>0.03</length>
            <radius>0.05</radius>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- Front caster -->
    <link name="caster_front_link">
      <pose relative_to="base_link">0.115 0 -0.0485 -1.57079632679 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>0.001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.001</iyy>
          <iyz>0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <visual name="caster_front_visual">
        <geometry>
          <cylinder>
            <length>0.03</length>
            <radius>0.025</radius>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.4 0.4 0.4 1</ambient>
          <diffuse>0.45 0.45 0.45 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <collision name="caster_front_collision">
        <geometry>
          <cylinder>
            <length>0.03</length>
            <radius>0.025</radius>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- Back caster -->
    <link name="caster_back_link">
      <pose relative_to="base_link">-0.135 0 -0.0485 -1.57079632679 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>0.001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.001</iyy>
          <iyz>0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <visual name="caster_back_visual">
        <geometry>
          <cylinder>
            <length>0.03</length>
            <radius>0.025</radius>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.4 0.4 0.4 1</ambient>
          <diffuse>0.45 0.45 0.45 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <collision name="caster_back_collision">
        <geometry>
          <cylinder>
            <length>0.03</length>
            <radius>0.025</radius>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- Sensor mount placeholder -->
    <link name="sensor_mount_link">
      <pose relative_to="base_link">0 0 0.07969 0 0 0</pose>
      <inertial>
        <mass>0.001</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000001</iyy>
          <iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      <visual name="sensor_mount_visual">
        <geometry>
          <box>
            <size>0.08 0.12 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0.25 0.25 0.25 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <collision name="sensor_mount_collision">
        <geometry>
          <box>
            <size>0.08 0.12 0.05</size>
          </box>
        </geometry>
      </collision>
    </link>

    <!-- Wheel joints -->
    <joint name="wheel_left_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_left_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>

    <joint name="wheel_right_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_right_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>

    <!-- Fixed joints -->
    <joint name="caster_front_joint" type="fixed">
      <parent>base_link</parent>
      <child>caster_front_link</child>
    </joint>

    <joint name="caster_back_joint" type="fixed">
      <parent>base_link</parent>
      <child>caster_back_link</child>
    </joint>

    <joint name="sensor_mount_joint" type="fixed">
      <parent>base_link</parent>
      <child>sensor_mount_link</child>
    </joint>

    <!-- Diff drive plugin for Stage 1 motion testing -->
    <plugin
      filename="ignition-gazebo-diff-drive-system"
      name="ignition::gazebo::systems::DiffDrive">
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.386</wheel_separation>
      <wheel_radius>0.05</wheel_radius>
      <topic>/model/qbot/cmd_vel</topic>
      <odom_topic>/model/qbot/odometry</odom_topic>
      <tf_topic>/model/qbot/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>

  </model>
</sdf>